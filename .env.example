# ============================================================
# FangHand Backend — Environment Variables
# Copy to .env and fill in real values
# ============================================================

# --- App ---
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=["http://localhost:3000"]

# --- Database (Supabase / PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fanghand
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
JWT_SECRET=your-jwt-secret
JWT_ALGORITHM=HS256

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_COLLECTOR=price_...
STRIPE_PRICE_RESEARCHER=price_...
STRIPE_PRICE_LEAD=price_...
STRIPE_PRICE_PREDICTOR=price_...
STRIPE_PRICE_TWITTER=price_...
STRIPE_PRICE_CLIP=price_...
STRIPE_PRICE_BROWSER=price_...
STRIPE_PRICE_BUNDLE_ANALYST=price_...
STRIPE_PRICE_BUNDLE_GROWTH=price_...
STRIPE_PRICE_BUNDLE_CREATOR=price_...
STRIPE_PRICE_BUNDLE_FULLSTACK=price_...

# --- Solana ---
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
PLATFORM_WALLET_PUBKEY=PLT1111111111111111111111111111111111111111
PLATFORM_BURN_KEYPAIR=
FGH_TOKEN_MINT=29W2v9vodbzFQWjshgq1u119VW8MvVgsksrLhZ5ipump
USDC_TOKEN_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
QUICK_RUN_LAMPORTS=8000000
DEEP_RUN_LAMPORTS=25000000
CREDIT_DEPOSIT_MIN=10000000

# --- OpenFang ---
OPENFANG_API_URL=http://localhost:4200
OPENFANG_API_KEY=your-openfang-api-key

# --- Redis ---
REDIS_URL=redis://localhost:6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Email (Resend) ---
RESEND_API_KEY=re_...
FROM_EMAIL=no-reply@fanghand.xyz

# --- Monitoring (Sentry) ---
SENTRY_DSN=https://your-sentry-dsn
